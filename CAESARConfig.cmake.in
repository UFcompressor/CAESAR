@PACKAGE_INIT@

set(CAESAR_ZSTD_LIBRARY "@ZSTD_LIBRARY@")
set(CAESAR_ZSTD_INCLUDE_DIR "@ZSTD_INCLUDE_DIR@")

include(CMakeFindDependencyMacro)

find_dependency(Torch REQUIRED)

if(NOT TARGET zstd_target)
    if(EXISTS "${CAESAR_ZSTD_LIBRARY}")
        add_library(zstd_target UNKNOWN IMPORTED)
        set_target_properties(zstd_target PROPERTIES
            IMPORTED_LOCATION "${CAESAR_ZSTD_LIBRARY}"
            INTERFACE_INCLUDE_DIRECTORIES "${CAESAR_ZSTD_INCLUDE_DIR}"
        )
    else()
        message(FATAL_ERROR "CAESAR was built with Zstd at ${CAESAR_ZSTD_LIBRARY} but it's not found")
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/CAESARTargets.cmake")
check_required_components(CAESAR)
